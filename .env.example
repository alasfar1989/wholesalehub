# =========================
# Backend Environment Variables
# =========================

# Server
PORT=3000
NODE_ENV=production

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/wholesalehub

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_EXPIRES_IN=30d

# Admin phone number (this user gets admin privileges on signup)
ADMIN_PHONE=+1234567890
